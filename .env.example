# ─── Application ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# ─── Database (Supabase) ──────────────────────────────────────
# Connection pooler URL — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL — used by Prisma migrations only (port 5432)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ─────────────────────────────────────────────────────
# Use a long random string. Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Seed (development only) ─────────────────────────────────
# Only used when running: npm run db:seed
SEED_ADMIN_EMAIL=admin@fitreserve.dev
SEED_ADMIN_PASSWORD=replace-with-strong-password
SEED_MEMBER_EMAIL=member@fitreserve.dev
SEED_MEMBER_PASSWORD=replace-with-strong-password
